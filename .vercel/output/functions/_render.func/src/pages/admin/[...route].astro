---
import Layout from '../../layouts/Layout.astro';
import AdminApp from '../../components/admin/AdminApp';

// Opt out of static rendering so React Router can handle dynamic sub-paths like /admin/login
export const prerender = false;
---

<Layout title="Voltag Gym | Portal Admin">
  <!-- We pass the static base path to React Router so internal links work perfectly -->
  <AdminApp basename="/admin" client:only="react" />
</Layout>

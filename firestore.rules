rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Forced redeploy from IDE
      // Allow complete read access for SSR from Firebase Admin.
      // Allow write access only to authenticated admin users on the client.
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

---
import Layout from '../../layouts/Layout.astro';
import { locations, getLocationBySlug } from '../../data/locations';

export function getStaticPaths() {
  return locations.map(loc => ({
    params: { slug: loc.slug },
    props: { location: loc },
  }));
}

const { location: loc } = Astro.props;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '573180046952';
const ctaUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`¡Hola Voltag! 💪 Soy del sector ${loc.shortName} y quiero más info sobre el gym.`)}`;

// Related locations (nearby sectors, exclude current)
const related = locations.filter(l => l.slug !== loc.slug).slice(0, 6);
---

<Layout title={loc.metaTitle} description={loc.metaDescription}>
  <!-- ── HERO ───────────────────────────────────── -->
  <header class="loc-hero">
    <div class="loc-hero__overlay"></div>
    <div class="container loc-hero__content">
      <!-- Breadcrumb -->
      <nav class="loc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Voltag Gym</a>
        <span>›</span>
        <a href="/gimnasio/">Gimnasios cerca</a>
        <span>›</span>
        <span>{loc.shortName}</span>
      </nav>

      <div class="loc-hero__badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Tu zona · {loc.shortName}
      </div>

      <h1 class="loc-hero__title">
        Gimnasio en<br /><span>{loc.name}</span>
      </h1>

      <p class="loc-hero__subtitle">
        {loc.hook}
      </p>

      <div class="loc-hero__distance">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Voltag Gym está {loc.distanceText} — <strong>Cl 12 # 20 Oeste - 10, Manzanares Sector 17</strong>
      </div>

      <div class="loc-hero__ctas">
        <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" id="loc-cta-wa">
          Empezar hoy — WhatsApp
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="/#planes" class="btn btn-secondary" id="loc-cta-plans">
          Ver planes →
        </a>
      </div>
    </div>
  </header>

  <!-- ── INFO CARDS ─────────────────────────────── -->
  <section class="loc-info">
    <div class="container">
      <div class="loc-info__grid">
        <div class="loc-info__card">
          <div class="loc-info__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Dirección</h3>
          <p>Cl 12 # 20 Oeste - 10<br />Manzanares Sector 17<br />Candelaria, Valle del Cauca</p>
        </div>
        <div class="loc-info__card">
          <div class="loc-info__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Horarios</h3>
          <p>Lun–Vie: 5:30 am – 10:00pm<br />Sábado: 6:00am – 4:00pm<br />Domingo: 8:00am – 12:00pm</p>
        </div>
        <div class="loc-info__card">
          <div class="loc-info__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <h3>Planes</h3>
          <p>Mensual: <strong>$70.000 COP</strong><br />Trimestral: <strong>$180.000 COP</strong><br />Anual: <strong>$600.000 COP</strong></p>
        </div>
        <div class="loc-info__card">
          <div class="loc-info__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Distancia</h3>
          <p>Desde <strong>{loc.shortName}</strong>:<br />{loc.distanceText}<br />Fácil acceso en moto o bus</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── DESCRIPTION ────────────────────────────── -->
  <section class="loc-desc">
    <div class="container loc-desc__grid">
      <div class="loc-desc__text">
        <div class="section-badge">Para residentes de {loc.shortName}</div>
        <h2 class="section-title">
          El Gym Que<br /><span>Necesitabas</span>
        </h2>
        <p class="loc-desc__body">{loc.description}</p>

        {loc.nearbyLandmarks.length > 0 && (
          <div class="loc-desc__landmarks">
            <p class="loc-desc__landmarks-label">📍 Cerca de:</p>
            <ul>
              {loc.nearbyLandmarks.map(lm => (
                <li>· {lm}</li>
              ))}
            </ul>
          </div>
        )}

        <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" id="loc-desc-cta">
          Hablar con el gym →
        </a>
      </div>

      <div class="loc-desc__features">
        <h3 class="loc-desc__features-title">¿Qué hay en Voltag Gym?</h3>
        <ul class="loc-desc__feature-list">
          {[
            ['Zona de Peso Libre', 'Barras, mancuernas y discos de alta carga'],
            ['Máquinas de Musculación', 'Equipos selectorizados para cada músculo'],
            ['Zona de Cardio', 'Trotadoras, elípticas y bicicletas'],
            ['Entrenamiento Personal', 'Coach certificados para tu plan'],
            ['Tienda de Suplementos', 'Proteínas, creatina y más en el gym'],
            ['Asesoría Nutricional', 'Plan de alimentación según tu meta'],
          ].map(([feature, desc]) => (
            <li class="loc-desc__feature-item">
              <span class="loc-desc__feature-check">✓</span>
              <div>
                <strong>{feature}</strong>
                <p>{desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── COMPETITOR SECTION (if applicable) ─────── -->
  {loc.competitors && loc.competitors.length > 0 && (
    <section class="loc-vs">
      <div class="container">
        <div class="loc-vs__header">
          <div class="section-badge">¿Por qué Voltag?</div>
          <h2 class="section-title">Voltag vs <span>Alternativas</span></h2>
        </div>
        <div class="loc-vs__table">
          <div class="loc-vs__row loc-vs__row--header">
            <div>Característica</div>
            <div class="loc-vs__col--voltag">Voltag Gym</div>
            <div>{loc.competitors[0] || 'Otros gyms'}</div>
          </div>
          {[
            ['Equipos profesionales', '✅ Grado comercial', '⚠️ Básicos'],
            ['Entrenadores certificados', '✅ Sí, incluido', '⚠️ Costo extra'],
            ['Precio mensual', '✅ $70.000 COP', '❓ Varía'],
            ['Horario amplios', '✅ 5:30 am–10pm L–V', '⚠️ Limitado'],
            ['Suplementos en gym', '✅ Tienda propia', '❌ No'],
            ['Ambiente motivador', '✅ Comunidad real', '⚠️ Variable'],
          ].map(([feat, voltag, other]) => (
            <div class="loc-vs__row">
              <div class="loc-vs__feat">{feat}</div>
              <div class="loc-vs__col--voltag">{voltag}</div>
              <div class="loc-vs__col--other">{other}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── CTA STRIP ───────────────────────────────── -->
  <section class="loc-cta-strip">
    <div class="container loc-cta-strip__inner">
      <div>
        <h2>¿Listo para empezar desde {loc.shortName}?</h2>
        <p>Un mensaje y te guiamos en el proceso. Sin compromisos, sin contratos trampa.</p>
      </div>
      <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" id="loc-strip-cta">
        Escríbenos por WhatsApp
      </a>
    </div>
  </section>

  <!-- ── OTHER LOCATIONS (Internal linking hub) ──── -->
  <section class="loc-other">
    <div class="container">
      <div class="section-badge">También cubrimos</div>
      <h2 class="section-title">Gimnasio Cerca en <span>Toda la Zona</span></h2>
      <div class="loc-other__grid">
        {related.map(rel => (
          <a href={`/gimnasio/${rel.slug}/`} class="loc-other__card">
            <span class="loc-other__card-label">{rel.shortName}</span>
            <span class="loc-other__card-dist">{rel.distanceText} →</span>
          </a>
        ))}
      </div>
      <p class="loc-other__back">
        <a href="/gimnasio/">← Ver todas las zonas</a>
      </p>
    </div>
  </section>

  <!-- ── MAP ───────────────────────────────────────── -->
  <section class="loc-map">
    <div class="container">
      <div class="section-badge">Ubicación</div>
      <h2 class="section-title">Cómo <span>Llegar</span></h2>
      <div class="loc-map__frame">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d991.8!2d-76.4397344!3d3.4012147!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sVoltag+Gym!5e0!3m2!1ses!2sco!4v1"
          width="100%"
          height="380"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Cómo llegar a Voltag Gym desde ${loc.name}`}
        ></iframe>
      </div>
    </div>
  </section>
</Layout>

<style>
/* ── Hero ─────────────────────────────────── */
.loc-hero {
  position: relative;
  min-height: 70vh;
  display: flex;
  align-items: center;
  background: 
    linear-gradient(135deg, rgba(5,5,5,0.97) 0%, rgba(5,5,5,0.85) 60%, rgba(212,25,32,0.15) 100%),
    url('/og-image.jpg') center / cover no-repeat;
  padding-top: calc(var(--nav-height) + 48px);
  padding-bottom: 80px;
}

.loc-hero__overlay {
  position: absolute;
  inset: 0;
  background: var(--black-pure);
  opacity: 0.65;
}

.loc-hero__content {
  position: relative;
  z-index: 2;
}

.loc-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.8rem;
  color: var(--gray);
  margin-bottom: 24px;
  flex-wrap: wrap;
}
.loc-breadcrumb a { color: var(--gray-light); }
.loc-breadcrumb a:hover { color: var(--red); }

.loc-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-heading);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--red);
  background: rgba(212,25,32,0.1);
  border: 1px solid rgba(212,25,32,0.3);
  padding: 8px 16px;
  margin-bottom: 20px;
}

.loc-hero__title {
  font-family: var(--font-display);
  font-size: clamp(2.8rem, 8vw, 5.5rem);
  line-height: 1;
  color: var(--white);
  margin-bottom: 20px;
}
.loc-hero__title span { color: var(--red); }

.loc-hero__subtitle {
  font-size: 1.1rem;
  color: var(--gray-light);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 20px;
}

.loc-hero__distance {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.9rem;
  color: var(--gray-light);
  margin-bottom: 36px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  padding: 12px 20px;
  width: fit-content;
}

.loc-hero__ctas {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.loc-hero__ctas .btn { text-decoration: none; }

/* ── Info Cards ─────────────────────────── */
.loc-info {
  background: var(--dark-surface);
  padding: 60px 0;
}
.loc-info__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.loc-info__card {
  background: var(--dark-card);
  border: 1px solid rgba(255,255,255,0.05);
  border-top: 2px solid var(--red);
  padding: 28px 24px;
  transition: transform 0.3s var(--transition);
}
.loc-info__card:hover { transform: translateY(-4px); }
.loc-info__icon { margin-bottom: 16px; }
.loc-info__card h3 {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 12px;
}
.loc-info__card p {
  font-size: 0.9rem;
  color: var(--gray-light);
  line-height: 1.6;
}

/* ── Description ────────────────────────── */
.loc-desc { background: var(--black); }
.loc-desc__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.loc-desc__body {
  color: var(--gray-light);
  line-height: 1.8;
  margin: 20px 0;
  font-size: 1rem;
}
.loc-desc__landmarks {
  background: rgba(255,255,255,0.03);
  border-left: 3px solid var(--red);
  padding: 16px 20px;
  margin-bottom: 32px;
}
.loc-desc__landmarks-label {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 8px;
}
.loc-desc__landmarks ul { display: flex; flex-direction: column; gap: 4px; }
.loc-desc__landmarks li { font-size: 0.9rem; color: var(--gray-light); }

.loc-desc__features-title {
  font-family: var(--font-heading);
  font-size: 1rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 24px;
}
.loc-desc__feature-list { display: flex; flex-direction: column; gap: 16px; }
.loc-desc__feature-item {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.loc-desc__feature-check {
  color: var(--red);
  font-size: 1.2rem;
  font-weight: bold;
  flex-shrink: 0;
  margin-top: 2px;
}
.loc-desc__feature-item strong {
  font-family: var(--font-heading);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--white);
  display: block;
  margin-bottom: 4px;
}
.loc-desc__feature-item p { font-size: 0.85rem; color: var(--gray); }

/* ── Competitor table ── */
.loc-vs { background: var(--dark); }
.loc-vs__header { margin-bottom: 40px; }
.loc-vs__table {
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 4px;
  overflow: hidden;
}
.loc-vs__row {
  display: grid;
  grid-template-columns: 2fr 1.5fr 1.5fr;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.loc-vs__row > div {
  padding: 14px 20px;
  font-size: 0.9rem;
  color: var(--gray-light);
  display: flex;
  align-items: center;
}
.loc-vs__row--header > div {
  background: rgba(212,25,32,0.08);
  font-family: var(--font-heading);
  font-size: 0.75rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
  font-weight: 700;
}
.loc-vs__col--voltag { background: rgba(212,25,32,0.04); font-weight: 600; color: var(--white) !important; }
.loc-vs__feat { font-weight: 500; }

/* ── CTA Strip ─────────────────────────── */
.loc-cta-strip {
  background: var(--red);
  padding: 60px 0;
}
.loc-cta-strip__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  flex-wrap: wrap;
}
.loc-cta-strip h2 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  color: var(--white-pure);
  margin-bottom: 8px;
}
.loc-cta-strip p { color: rgba(255,255,255,0.85); font-size: 0.95rem; }
.loc-cta-strip .btn-primary {
  background: var(--white-pure);
  color: var(--red);
  white-space: nowrap;
}
.loc-cta-strip .btn-primary:hover { background: var(--black-pure); color: var(--white-pure); }

/* ── Other locations ────────────────────── */
.loc-other { background: var(--black); }
.loc-other__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin: 40px 0 24px;
}
.loc-other__card {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 20px;
  background: var(--dark-card);
  border: 1px solid rgba(255,255,255,0.05);
  border-left: 3px solid var(--red);
  transition: all 0.3s var(--transition);
  text-decoration: none;
}
.loc-other__card:hover {
  background: var(--dark-card-hover);
  transform: translateX(4px);
}
.loc-other__card-label {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--white);
}
.loc-other__card-dist { font-size: 0.8rem; color: var(--gray); }
.loc-other__back { text-align: center; margin-top: 8px; }
.loc-other__back a { color: var(--gray); font-size: 0.9rem; }
.loc-other__back a:hover { color: var(--red); }

/* ── Map ─────────────────────────────────── */
.loc-map { background: var(--dark); }
.loc-map__frame {
  margin-top: 40px;
  border: 1px solid rgba(255,255,255,0.06);
  filter: brightness(0.9) contrast(1.05);
}

/* ── Responsive ─────────────────────────── */
@media (max-width: 900px) {
  .loc-info__grid { grid-template-columns: 1fr 1fr; }
  .loc-desc__grid { grid-template-columns: 1fr; gap: 40px; }
  .loc-other__grid { grid-template-columns: 1fr 1fr; }
  .loc-vs__row { grid-template-columns: 1.5fr 1fr 1fr; }
  .loc-vs__row > div { padding: 10px 12px; font-size: 0.8rem; }
  .loc-cta-strip__inner { flex-direction: column; text-align: center; }
}
@media (max-width: 600px) {
  .loc-info__grid { grid-template-columns: 1fr; }
  .loc-other__grid { grid-template-columns: 1fr; }
  .loc-vs__row { grid-template-columns: 1fr 1fr; }
  .loc-vs__row > div:last-child { display: none; }
}
</style>

---
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '573180046952';
const mapsUrl = import.meta.env.PUBLIC_GOOGLE_MAPS_URL || 'https://maps.app.goo.gl/oDdrQTzTKmmzR4d96';
---

<section class="location" id="ubicacion">
  <div class="container">
    <div class="location__header reveal">
      <div class="section-badge">Ubicación</div>
      <h2 class="section-title">Encuéntranos En <span>Manzanares</span></h2>
      <p class="section-subtitle">
        Estamos en el corazón de Manzanares Sector 17, Ciudad del Valle — Candelaria. 
        Ven a conocernos y descubre por qué somos el gym preferido del sector.
      </p>
    </div>

    <div class="location__grid">
      <div class="location__info reveal">
        <div class="location__info-item">
          <div class="location__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <strong>Dirección</strong>
            <p>Cl 12 # 20 Oeste - 10<br />Manzanares Sector 17<br />Ciudad del Valle, Candelaria</p>
          </div>
        </div>

        <div class="location__info-item">
          <div class="location__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <strong>Horarios</strong>
            <p>Lunes a Viernes: 05:30 AM - 10:00 PM</p>
            <p>Sábados: 08:00 AM - 02:00 PM</p>
          </div>
        </div>

        <div class="location__info-item">
          <div class="location__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <strong>WhatsApp</strong>
            <a href={`https://wa.me/${whatsappNumber}`} target="_blank" rel="noopener noreferrer" class="location__phone">
              +57 318 004 6952
            </a>
          </div>
        </div>

        <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary location__map-btn" id="location-maps-btn">
          Abrir en Google Maps
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
        </a>
      </div>

      <div class="location__map reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3982.8!2d-76.4397344!3d3.4012147!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zM8KwMjQnMDQuNCJOIDc2wrAyNicyMy4wIlc!5e0!3m2!1ses!2sco!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Voltag Gym en Manzanares Sector 17, Candelaria - Google Maps"
        ></iframe>
        <div class="location__map-overlay">
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="location__map-link">
            Ver mapa completo
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .location {
    background: var(--dark);
  }

  .location__header {
    margin-bottom: 48px;
  }

  .location__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .location__info {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .location__info-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .location__info-icon {
    min-width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(230, 57, 70, 0.08);
    border: 1px solid rgba(230, 57, 70, 0.15);
  }

  .location__info-item strong {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--white);
    display: block;
    margin-bottom: 6px;
  }

  .location__info-item p {
    font-size: 0.875rem;
    color: var(--gray);
    line-height: 1.6;
  }

  .location__phone {
    font-size: 0.95rem;
    color: var(--red);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s;
  }

  .location__phone:hover {
    color: var(--white);
  }

  .location__map-btn {
    text-decoration: none;
    margin-top: 8px;
    align-self: flex-start;
  }

  .location__map {
    position: relative;
    height: 400px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .location__map iframe {
    filter: grayscale(0.8) contrast(1.1) brightness(0.7);
    transition: filter 0.4s;
  }

  .location__map:hover iframe {
    filter: grayscale(0.3) contrast(1.05) brightness(0.85);
  }

  .location__map-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px;
    background: linear-gradient(transparent, rgba(10, 10, 10, 0.9));
    display: flex;
    justify-content: flex-end;
  }

  .location__map-link {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--red);
    text-decoration: none;
    transition: color 0.3s;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .location__map-link:hover {
    color: var(--white);
  }

  @media (max-width: 900px) {
    .location__grid {
      grid-template-columns: 1fr;
    }

    .location__map {
      height: 300px;
    }
  }
</style>

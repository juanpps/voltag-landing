---
import PromoTopBanner from './PromoTopBanner.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero/hero-gym.jpg';

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '573180046952';
const ctaUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('¡Hola Voltag! 💪 Quiero empezar a entrenar hoy.')}`;
---

<section class="hero scanlines" id="hero">
  <div class="hero__bg">
    <Image
      src={heroImg}
      alt="Interior de Voltag Gym — Gimnasio profesional en Manzanares Sector 17, Candelaria"
      width={1920}
      height={1080}
      quality={80}
      format="webp"
      loading="eager"
      class="hero__img"
    />
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__content container">
    <PromoTopBanner />
    <div class="hero__badge">
      <svg class="hero__badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      Since 2024 — Voltag Gym
    </div>

    <h1 class="hero__title">
      Gimnasio en<br />
      <span>Manzanares</span>
    </h1>
    <p class="hero__eyebrow">Activa Tu Poder Interior</p>

    <p class="hero__subtitle">
      El gimnasio de Manzanares que te empuja a ser mejor cada día. 
      Equipos profesionales, entrenadores certificados y la energía que necesitas — todo en tu sector.
    </p>

    <div class="hero__ctas">
      <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" id="hero-cta-primary">
        Empieza hoy
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="#instalaciones" class="btn btn-secondary" id="hero-cta-secondary">
        Ver instalaciones
      </a>
    </div>

    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-number">2+</span>
        <span class="hero__stat-label">Pisos</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-number">100%</span>
        <span class="hero__stat-label">Equipado</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-number">2024</span>
        <span class="hero__stat-label">Since</span>
      </div>
    </div>
  </div>

  <div class="hero__scroll">
    <div class="hero__scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: slowZoom 20s ease-in-out infinite alternate;
    filter: brightness(0.35) contrast(1.15) saturate(0.8);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(5, 5, 5, 0.9) 0%,
      rgba(5, 5, 5, 0.55) 50%,
      rgba(212, 25, 32, 0.2) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    animation: fadeUp 1s ease-out;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 24px;
    padding: 8px 16px;
    border: 1px solid rgba(212, 25, 32, 0.4);
    background: rgba(212, 25, 32, 0.1);
  }

  .hero__badge-icon {
    color: var(--red);
    animation: float 3s ease-in-out infinite;
    flex-shrink: 0;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 0.95;
    color: var(--white);
    margin-bottom: 24px;
  }

  .hero__title span {
    color: var(--red);
    text-shadow: 0 0 80px var(--red-glow-strong);
  }

  .hero__eyebrow {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gray-light);
    margin: -12px 0 24px 0;
    opacity: 0.75;
  }

  .hero__subtitle {
    font-size: 1.1rem;
    color: var(--gray-light);
    max-width: 500px;
    line-height: 1.8;
    margin-bottom: 40px;
  }

  .hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 60px;
  }

  .hero__ctas .btn {
    text-decoration: none;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
  }

  .hero__stat-number {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--white);
  }

  .hero__stat-label {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gray);
  }

  .hero__stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
  }

  .hero__scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 3;
  }

  .hero__scroll span {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gray);
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(230, 57, 70, 0.5);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--red);
    animation: scrollLine 2s infinite;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 100svh;
    }

    .hero__title {
      font-size: clamp(2.8rem, 12vw, 4.5rem);
    }

    .hero__stats {
      gap: 20px;
    }

    .hero__stat-number {
      font-size: 1.5rem;
    }

    .hero__scroll {
      display: none;
    }
  }
</style>

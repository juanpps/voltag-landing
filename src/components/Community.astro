---
import { Image } from 'astro:assets';
import communityImg from '../assets/images/community/community-group.jpg';
import communityHug from '../assets/images/community/community-hug.jpg';
import garciaBg from '../assets/images/gallery/garcia-entrance.jpg';
---

<section class="community" id="comunidad">
  <div class="container">
    <div class="community__header reveal">
      <div class="section-badge">Comunidad</div>
      <h2 class="section-title">
        Más Que Un Gym,<br />
        <span>Somos <span class="rotator" id="word-rotator">Familia</span></span>
      </h2>
      <p class="section-subtitle">
        Aquí no vienes solo a entrenar — vienes a conectar con gente que persigue 
        las mismas metas que tú. Únete a la familia Voltag.
      </p>
    </div>

    <div class="community__grid">
      <div class="community__photo community__photo--main reveal">
        <Image
          src={communityImg}
          alt="Comunidad Voltag Gym — Foto grupal de miembros y equipo"
          width={800}
          height={500}
          quality={80}
          format="webp"
          class="community__img"
        />
        <div class="community__photo-overlay"></div>
        <div class="community__photo-label">La Familia Voltag</div>
      </div>

      <div class="community__side">
        <div class="community__photo reveal">
          <Image
            src={communityHug}
            alt="Miembro abrazando al entrenador frente a Voltag Gym"
            width={400}
            height={350}
            quality={80}
            format="webp"
            class="community__img"
          />
          <div class="community__photo-overlay"></div>
        </div>
        <div class="community__photo reveal">
          <Image
            src={garciaBg}
            alt="Fachada de Voltag Gym en la inauguración"
            width={400}
            height={350}
            quality={80}
            format="webp"
            class="community__img"
          />
          <div class="community__photo-overlay"></div>
        </div>
      </div>
    </div>

    <div class="community__stats reveal">
      <div class="community__stat">
        <span class="community__stat-number">100+</span>
        <span class="community__stat-label">Miembros Activos</span>
      </div>
      <div class="community__stat-divider"></div>
      <div class="community__stat">
        <span class="community__stat-number">2</span>
        <span class="community__stat-label">Pisos Equipados</span>
      </div>
      <div class="community__stat-divider"></div>
      <div class="community__stat">
        <span class="community__stat-number">100%</span>
        <span class="community__stat-label">Compromiso</span>
      </div>
      <div class="community__stat-divider"></div>
      <div class="community__stat">
        <span class="community__stat-number">5:30am</span>
        <span class="community__stat-label">Abrimos Temprano</span>
      </div>
    </div>
  </div>
</section>

<script>
  const words = ['Familia', 'Comunidad', 'Unión', 'Ayuda', 'Fuerza', 'Poder'];
  let currentIndex = 0;
  const rotator = document.getElementById('word-rotator');

  if (rotator) {
    setInterval(() => {
      rotator.classList.add('rotator--out');
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % words.length;
        rotator.textContent = words[currentIndex];
        rotator.classList.remove('rotator--out');
        rotator.classList.add('rotator--in');
        setTimeout(() => rotator.classList.remove('rotator--in'), 500);
      }, 400);
    }, 2800);
  }
</script>

<style>
  .community {
    background: var(--dark);
  }

  .community__header {
    margin-bottom: 48px;
  }

  /* ── Word Rotator ──────────────────────────────── */
  .rotator {
    display: inline-block;
    position: relative;
    color: var(--red);
    transition: opacity 0.4s ease, transform 0.4s ease;
    min-width: 180px;
  }

  .rotator--out {
    opacity: 0;
    transform: translateY(20px);
  }

  .rotator--in {
    animation: rotatorEnter 0.5s var(--transition-spring) forwards;
  }

  @keyframes rotatorEnter {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .community__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    grid-template-rows: 340px;
    gap: 12px;
    margin-bottom: 48px;
  }

  .community__photo {
    position: relative;
    overflow: hidden;
  }

  .community__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.7s var(--transition);
    filter: saturate(0.8);
  }

  .community__photo:hover .community__img {
    transform: scale(1.05);
    filter: saturate(1);
  }

  .community__photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.5), transparent 50%);
    transition: background 0.4s;
  }

  .community__photo:hover .community__photo-overlay {
    background: linear-gradient(to top, rgba(212, 25, 32, 0.2), transparent 50%);
  }

  .community__photo--main {
    height: 100%;
  }

  .community__photo-label {
    position: absolute;
    bottom: 16px;
    left: 20px;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--white);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .community__photo-label::before {
    content: '';
    width: 30px;
    height: 2px;
    background: var(--red);
  }

  .community__side {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 12px;
    overflow: hidden;
  }

  /* Stats bar */
  .community__stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    padding: 40px 0;
    border-top: 1px solid rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .community__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .community__stat-number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--red);
    line-height: 1;
    margin-bottom: 6px;
  }

  .community__stat-label {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gray);
  }

  .community__stat-divider {
    width: 1px;
    height: 50px;
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 900px) {
    .community__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .community__photo--main {
      height: 220px;
    }

    .community__photo {
      height: 160px;
    }

    .community__side {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 160px;
    }

    .community__stats {
      flex-wrap: wrap;
      gap: 24px;
    }

    .community__stat-divider {
      display: none;
    }

    .community__stat-number {
      font-size: 2rem;
    }
  }
</style>

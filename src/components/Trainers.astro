---
import { Image } from 'astro:assets';
import coachGarcia from '../assets/images/coaches/coach-garcia.png';
import coachSegundo from '../assets/images/coaches/coach-segundo.png';

const secondTrainerName = import.meta.env.PUBLIC_SECOND_TRAINER_NAME || 'Segundo';

const trainers = [
  {
    name: 'García',
    role: 'Head Coach — Fundador',
    bio: 'Apasionado por el fitness y la transformación personal. Fundador de Voltag Gym con años de experiencia en entrenamiento de fuerza y acondicionamiento físico.',
    photo: coachGarcia,
    alt: 'Coach García - Head Coach y Fundador de Voltag Gym en Manzanares',
    specialties: ['Fuerza', 'Hipertrofia', 'Nutrición'],
  },
  {
    name: secondTrainerName,
    role: 'Personal Trainer',
    bio: 'Entrenador certificado especializado en transformación corporal y entrenamiento funcional. Tu guía para alcanzar resultados que nunca imaginaste.',
    photo: coachSegundo,
    alt: `Coach ${secondTrainerName} - Personal Trainer en Voltag Gym`,
    specialties: ['Funcional', 'Cardio', 'Resistencia'],
  },
];
---

<section class="trainers" id="entrenadores">
  <div class="container">
    <div class="trainers__header reveal">
      <div class="section-badge">Entrenadores</div>
      <h2 class="section-title">Tu Equipo De <span>Poder</span></h2>
      <p class="section-subtitle">
        Entrenadores certificados que se convierten en tu guía, tu motivación y tu apoyo. 
        No estás solo en este camino.
      </p>
    </div>

    <div class="trainers__grid">
      {trainers.map((trainer, i) => (
        <article class={`trainers__card reveal trainers__card--${i === 0 ? 'left' : 'right'}`}>
          {/* Portrait */}
          <div class="trainers__card-portrait">
            <div class="trainers__card-portrait-bg"></div>
            <Image
              src={trainer.photo}
              alt={trainer.alt}
              width={460}
              height={560}
              quality={90}
              format="webp"
              class="trainers__card-img"
            />
            <div class="trainers__card-portrait-ring"></div>
          </div>

          {/* Info */}
          <div class="trainers__card-info">
            <span class="trainers__card-role">{trainer.role}</span>
            <h3 class="trainers__card-name">{trainer.name}</h3>
            <p class="trainers__card-bio">{trainer.bio}</p>
            <div class="trainers__card-tags">
              {trainer.specialties.map(tag => (
                <span class="trainers__tag">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  {tag}
                </span>
              ))}
            </div>
          </div>

          {/* Bottom accent */}
          <div class="trainers__card-accent"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .trainers {
    background: var(--black-pure);
    overflow: hidden;
  }

  .trainers__header {
    margin-bottom: 60px;
  }

  .trainers__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  /* ── Card ─────────────────────────────────────────── */
  .trainers__card {
    background: var(--dark-card);
    border: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 48px 36px 40px;
    position: relative;
    transition: all 0.5s var(--transition);
  }

  .trainers__card:hover {
    border-color: rgba(212, 25, 32, 0.25);
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  /* Slide-in from left / right */
  .trainers__card--left {
    transform: translateX(-60px);
    opacity: 0;
    transition: opacity 0.8s var(--transition), transform 0.8s var(--transition);
  }

  .trainers__card--right {
    transform: translateX(60px);
    opacity: 0;
    transition: opacity 0.8s var(--transition), transform 0.8s var(--transition);
    transition-delay: 0.15s;
  }

  .trainers__card--left.visible,
  .trainers__card--right.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .trainers__card--left.visible:hover,
  .trainers__card--right.visible:hover {
    transform: translateX(0) translateY(-8px);
  }

  /* ── Portrait ────────────────────────────────────── */
  .trainers__card-portrait {
    position: relative;
    width: 100%;
    max-width: 260px;
    aspect-ratio: 5 / 6;
    margin-bottom: 28px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: visible;
  }

  .trainers__card-portrait-bg {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    aspect-ratio: 1;
    background: radial-gradient(ellipse at center, rgba(212, 25, 32, 0.12) 0%, transparent 70%);
    border-radius: 50%;
    transition: all 0.6s var(--transition);
    z-index: 0;
  }

  .trainers__card:hover .trainers__card-portrait-bg {
    width: 95%;
    background: radial-gradient(ellipse at center, rgba(212, 25, 32, 0.2) 0%, transparent 70%);
  }

  .trainers__card-img {
    position: relative;
    z-index: 1;
    width: auto;
    max-width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.6));
    transition: transform 0.6s var(--transition-spring), filter 0.5s;
  }

  .trainers__card:hover .trainers__card-img {
    transform: scale(1.08) translateY(-6px);
    filter: drop-shadow(0 12px 36px rgba(0, 0, 0, 0.7));
  }

  .trainers__card-portrait-ring {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 20px;
    background: radial-gradient(ellipse at center, rgba(212, 25, 32, 0.15), transparent 70%);
    border-radius: 50%;
    z-index: 0;
    transition: opacity 0.5s, width 0.5s;
  }

  .trainers__card:hover .trainers__card-portrait-ring {
    width: 85%;
    opacity: 0.8;
  }

  /* ── Info ─────────────────────────────────────────── */
  .trainers__card-info {
    width: 100%;
  }

  .trainers__card-role {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--red);
    display: block;
    margin-bottom: 8px;
  }

  .trainers__card-name {
    font-family: var(--font-display);
    font-size: 3.2rem;
    color: var(--white);
    line-height: 1;
    letter-spacing: 2px;
    margin-bottom: 16px;
    transition: text-shadow 0.4s;
  }

  .trainers__card:hover .trainers__card-name {
    text-shadow: 0 0 40px var(--red-glow);
  }

  .trainers__card-bio {
    font-size: 0.875rem;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 380px;
    margin-left: auto;
    margin-right: auto;
  }

  .trainers__card-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .trainers__tag {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 7px 18px;
    border: 1px solid rgba(212, 25, 32, 0.25);
    color: var(--red);
    background: rgba(212, 25, 32, 0.05);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.3s;
  }

  .trainers__card:hover .trainers__tag {
    border-color: rgba(212, 25, 32, 0.5);
    background: rgba(212, 25, 32, 0.1);
  }

  /* ── Accent bar ──────────────────────────────────── */
  .trainers__card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--red), var(--red-intense));
    transition: width 0.6s var(--transition);
  }

  .trainers__card:hover .trainers__card-accent {
    width: 100%;
    box-shadow: 0 0 20px var(--red-glow);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .trainers__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .trainers__card {
      padding: 32px 20px 28px;
    }

    .trainers__card--left,
    .trainers__card--right {
      transform: translateY(50px);
    }

    .trainers__card-portrait {
      max-width: 220px;
    }

    .trainers__card-name {
      font-size: 2.6rem;
    }

    .trainers__card-bio {
      font-size: 0.82rem;
    }
  }
</style>

---

<section class="testimonials" id="testimonios">
  <div class="container">
    <div class="testimonials__header reveal">
      <div class="section-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--red)" style="margin-right: 6px; vertical-align: middle;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Google Reviews
      </div>
      <h2 class="section-title">Lo Que Dice Nuestra <span>Comunidad</span></h2>
      <p class="section-subtitle">
        Historias reales y verificadas de nuestros atletas en Google Negocios.
      </p>
    </div>

    <!-- Elfsight Google Reviews SEO Widget -->
    <div class="testimonials__widget reveal" style="transition-delay: 0.1s; margin-top: 24px;">
      <script src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-7cd4b57f-3965-4c92-8df8-51cc67e5e53a" data-elfsight-app-lazy></div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--black);
  }

  .testimonials__header {
    margin-bottom: 24px;
  }

  .testimonials__widget {
    background: #ffffff;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
    /* By forcing a white background, the dark text of the Elfsight widget becomes fully readable */
  }
</style>

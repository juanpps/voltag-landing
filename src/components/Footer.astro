---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo/logo-white.png';

import DynamicSocials from './DynamicSocials.jsx';
import DynamicContactLinks from './DynamicContactLinks.jsx';
import { doc, getDoc } from 'firebase/firestore';
import { db } from '../utils/firebase.client';

let whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '573180046952';
let instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL || 'https://www.instagram.com/voltag_gym';
let tiktokUrl = import.meta.env.PUBLIC_TIKTOK_URL || 'https://www.tiktok.com/@voltag_gym';
let mapsUrl = import.meta.env.PUBLIC_GOOGLE_MAPS_URL || 'https://maps.app.goo.gl/oDdrQTzTKmmzR4d96';
let globalAddress = 'Cl 12 # 20 Oeste - 10';

const timeoutPromise = new Promise((_, reject) => setTimeout(() => reject(new Error('timeout')), 1000));

try {
  const globalRef = doc(db, 'configuracion', 'global');
  const globalSnap = await Promise.race([getDoc(globalRef), timeoutPromise]);
  if (globalSnap && globalSnap.exists()) {
    const data = globalSnap.data();
    if (data.whatsapp) whatsappNumber = data.whatsapp;
    if (data.instagram) instagramUrl = data.instagram;
    if (data.tiktok) tiktokUrl = data.tiktok;
    if (data.mapsUrl) mapsUrl = data.mapsUrl;
    if (data.address) globalAddress = data.address;
  }
} catch(e) { /* fallback active */ }

const whatsappUrl = `https://wa.me/${whatsappNumber}`;

const navLinks = [
  { label: 'Inicio', href: '#hero' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Instalaciones', href: '#instalaciones' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Planes', href: '#planes' },
  { label: 'Ubicación', href: '#ubicacion' },
];

const socialLinks = [
  {
    label: 'Instagram',
    href: instagramUrl,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: 'TikTok',
    href: tiktokUrl,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13a8.27 8.27 0 005.58 2.17V11.7a4.84 4.84 0 01-3.77-1.24V6.69h3.77z"/></svg>`,
  },
  {
    label: 'WhatsApp',
    href: whatsappUrl,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  },
  {
    label: 'Google Maps',
    href: mapsUrl,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];
---

<footer class="footer" id="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a href="#hero" class="footer__logo" aria-label="Voltag Gym - Inicio">
        <Image
          src={logoImg}
          alt="Voltag Gym Logo"
          width={140}
          height={50}
          quality={90}
          class="footer__logo-img"
        />
      </a>
      <p class="footer__desc">
        El gimnasio que tu barrio merecía. Equipos profesionales, entrenadores certificados 
        y la comunidad fitness más fuerte de Manzanares, Candelaria.
      </p>
      <div className="footer__social">
        <DynamicSocials client:load />
      </div>
    </div>

    <div class="footer__nav">
      <h4 class="footer__heading">Navegación</h4>
      <ul class="footer__links">
        {navLinks.map(link => (
          <li><a href={link.href} class="footer__link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__contact">
      <h4 class="footer__heading">Contacto</h4>
      <DynamicContactLinks client:load />
    </div>

    <div class="footer__zones">
      <h4 class="footer__heading">Zonas que Cubrimos</h4>
      <ul class="footer__links">
        <li><a href="/gimnasio/manzanares-sector-17/" class="footer__link">Manzanares Sector 17</a></li>
        <li><a href="/gimnasio/poblado-campestre/" class="footer__link">Poblado Campestre</a></li>
        <li><a href="/gimnasio/arboleda-campestre/" class="footer__link">Arboleda Campestre</a></li>
        <li><a href="/gimnasio/ciudad-del-valle/" class="footer__link">Ciudad del Valle</a></li>
        <li><a href="/gimnasio/candelaria/" class="footer__link">Candelaria</a></li>
        <li><a href="/gimnasio/sur-de-cali/" class="footer__link">Sur de Cali</a></li>
        <li><a href="/gimnasio/" class="footer__link footer__link--all">→ Ver todas las zonas</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {new Date().getFullYear()} Voltag Gym. Todos los derechos reservados.</p>
      
      <div style="display: flex; flex-direction: column; align-items: flex-end;">
        <!-- Credito de Desarrollador MagnusCode -->
        <a href="https://wa.me/573106229007" target="_blank" rel="noopener noreferrer" class="footer__developer">
          <span>Desarrollado por</span>
          <img src="/magnuscode-logo.png" alt="MagnusCode" style="height: 18px; width: auto; object-fit: contain; filter: grayscale(100%) brightness(1.5); transition: all 0.3s;" class="magnus-logo" />
        </a>
      </div>
    </div>
  </div>
</footer>


<style>
  .footer {
    background: var(--dark);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding-top: 80px;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 60px;
  }

  .footer__logo {
    display: inline-block;
    margin-bottom: 20px;
    text-decoration: none;
  }

  .footer__logo-img {
    height: 44px;
    width: auto;
    object-fit: contain;
    filter: brightness(1.1);
    transition: filter 0.3s;
  }

  .footer__logo:hover .footer__logo-img {
    filter: brightness(1.3);
  }

  .footer__desc {
    font-size: 0.875rem;
    color: var(--gray);
    line-height: 1.7;
    max-width: 360px;
    margin-bottom: 24px;
  }

  .footer__social {
    display: flex;
    gap: 12px;
  }

  .footer__social-link {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--gray);
    text-decoration: none;
    transition: all 0.3s;
  }

  .footer__social-link:hover {
    border-color: var(--red);
    color: var(--red);
    background: rgba(230, 57, 70, 0.08);
    transform: translateY(-2px);
  }

  .footer__heading {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 24px;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__link {
    font-size: 0.875rem;
    color: var(--gray);
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer__link:hover {
    color: var(--red);
  }

  .footer__link--icon {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .footer__link--static {
    cursor: default;
  }

  .footer__link--static:hover {
    color: var(--gray);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding: 24px 0;
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__bottom p {
    font-size: 0.8rem;
    color: var(--gray);
  }

  .footer__credits {
    font-size: 0.75rem;
    color: var(--gray);
    opacity: 0.6;
    margin-bottom: 8px;
  }

  .footer__developer {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    transition: all 0.3s ease;
  }
  
  .footer__developer:hover {
    background: rgba(212, 25, 32, 0.1);
    border-color: rgba(212, 25, 32, 0.3);
    transform: translateY(-2px);
  }

  .footer__developer:hover .magnus-logo {
    filter: grayscale(0%) brightness(1) !important;
  }

  .footer__developer span {
    font-size: 0.7rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer__developer strong {
    font-family: var(--font-heading, "Outfit", sans-serif);
    color: var(--red, #d41920);
    font-size: 0.85rem;
    letter-spacing: 1px;
    font-weight: 800;
  }

  .footer__link--all {
    color: var(--red) !important;
    font-weight: 600;
    margin-top: 4px;
    display: inline-block;
  }
  .footer__link--all:hover { opacity: 0.8; }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }

    .footer__bottom-inner {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
    
    .footer__bottom-inner div {
      align-items: center !important;
    }
  }
</style>
